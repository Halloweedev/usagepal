{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UsagePal",
  "version": "0.7.0",
  "identifier": "com.halloweed.usagepal",
  "build": {
    "beforeDevCommand": "bun run bundle:plugins && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run bundle:plugins && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UsagePal",
        "width": 400,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' tauri://localhost"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/bundled_plugins/**/*",
      "icons/tray-icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "RWTTWPopyR0Ik7bsAxq5BVjbEkzqnTMGOjgTjRjoznmEr002h9Dj6ROy",
      "endpoints": [
        "https://github.com/Halloweedev/usagepal/releases/latest/download/latest.json"
      ]
    }
  }
}
