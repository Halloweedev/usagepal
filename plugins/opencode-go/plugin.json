{
  "schemaVersion": 1,
  "id": "opencode-go",
  "name": "OpenCode Go",
  "version": "0.0.1",
  "entry": "plugin.js",
  "icon": "icon.svg",
  "brandColor": "#000000",
  "detect": [{ "file": "~/.local/share/opencode/auth.json" }],
  "links": [
    {
      "label": "Console",
      "url": "https://opencode.ai/auth"
    },
    {
      "label": "Docs",
      "url": "https://opencode.ai/docs/go/"
    }
  ],
  "lines": [
    {
      "type": "progress",
      "label": "Session",
      "scope": "overview",
      "primaryOrder": 1
    },
    {
      "type": "progress",
      "label": "Weekly",
      "scope": "overview",
      "period": "weekly"
    },
    {
      "type": "progress",
      "label": "Monthly",
      "scope": "overview",
      "escalateAtPercent": 98
    },
    { "type": "text", "label": "Today", "scope": "detail" },
    { "type": "text", "label": "Yesterday", "scope": "detail" },
    { "type": "text", "label": "Last 30 Days", "scope": "detail" },
    { "type": "barChart", "label": "Usage Trend", "scope": "detail" }
  ]
}