{
  "schemaVersion": 1,
  "id": "cline-pass",
  "name": "ClinePass",
  "version": "0.0.1",
  "entry": "plugin.js",
  "icon": "icon.svg",
  "brandColor": "#000000",
  "detect": [
    { "file": "~/.cline/data/settings/providers.json" },
    { "file": "~/.config/cline/providers.json" },
    { "env": "CLINE_API_KEY" }
  ],
  "links": [
    { "label": "Dashboard", "url": "https://app.cline.bot/dashboard/subscription" },
    { "label": "API Keys", "url": "https://app.cline.bot/dashboard" }
  ],
  "lines": [
    { "type": "progress", "label": "Session", "scope": "overview", "primaryOrder": 1 },
    { "type": "progress", "label": "Weekly", "scope": "overview", "period": "weekly" },
    { "type": "progress", "label": "Monthly", "scope": "overview" },
    { "type": "text", "label": "Balance", "scope": "overview" },
    { "type": "text", "label": "Today", "scope": "detail" },
    { "type": "text", "label": "Yesterday", "scope": "detail" },
    { "type": "text", "label": "Last 30 Days", "scope": "detail" },
    { "type": "barChart", "label": "Usage Trend", "scope": "detail" }
  ]
}
