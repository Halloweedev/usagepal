{
  "schemaVersion": 1,
  "id": "zai",
  "name": "Z.ai",
  "version": "0.0.1",
  "entry": "plugin.js",
  "icon": "icon.svg",
  "brandColor": "#2D2D2D",
  "detect": [
    { "env": "ZAI_API_KEY" },
    { "env": "GLM_API_KEY" }
  ],
  "lines": [
    { "type": "progress", "label": "Session", "scope": "overview", "primaryOrder": 1 },
    { "type": "progress", "label": "Weekly", "scope": "overview", "period": "weekly" },
    { "type": "progress", "label": "Web Searches", "scope": "overview" }
  ]
}
