# Tauri updater signing
TAURI_SIGNING_PRIVATE_KEY=/path/to/your.key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# macOS code signing
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Notarization
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=

# Keylight licensing (keylight.dev) — publishable client identifiers, NOT secret.
# Copy these from your Keylight dashboard. Leave blank until the donation product
# exists; the app builds and runs without them (no analytics/licensing until set).
KEYLIGHT_TENANT=
KEYLIGHT_PRODUCT=
KEYLIGHT_SDK_KEY=
KEYLIGHT_PUBKEY_KID=
KEYLIGHT_PUBKEY=
